[flake8]
# Flake8 configuration for Spotify RecSys project

# Maximum line length
max-line-length = 120

# Ignore rules
ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
    W504,  # line break after binary operator
    F401,  # module imported but unused (handled by isort)

# Exclude directories
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    .eggs,
    *.egg-info,
    .pytest_cache,
    .tox,
    mlruns,
    .github

# Complexity checks
max-complexity = 10

# Per-file ignores
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811

# Output format
format = default
